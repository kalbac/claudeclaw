# === Telegram (optional — auto-read from ~/.claude/channels/telegram/) ===
# TELEGRAM_BOT_TOKEN=only-if-different-from-channels
# ALLOWED_CHAT_ID=only-if-different-from-channels

# === Voice (Groq Whisper STT — free at console.groq.com) ===
GROQ_API_KEY=your-groq-api-key

# === Email (IMAP — default: Yandex) ===
IMAP_EMAIL=you@yandex.ru
IMAP_PASSWORD=your-app-password
# IMAP_HOST=imap.yandex.ru
# IMAP_PORT=993
# For Gmail: IMAP_HOST=imap.gmail.com
# For Outlook: IMAP_HOST=outlook.office365.com

# === Dashboard ===
DASHBOARD_PORT=3141
DASHBOARD_TOKEN=your-dashboard-auth-token

# === Optional ===
# LOG_LEVEL=info
# AGENT_TIMEOUT_MS=900000
# HEARTBEAT_DISABLED=false
# HEARTBEAT_INTERVAL_MS=1800000
# HEARTBEAT_ACTIVE_START=9
# HEARTBEAT_ACTIVE_END=22
